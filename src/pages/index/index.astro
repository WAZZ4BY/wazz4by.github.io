---
import BaseLayout from '../../layouts/BaseLayout.astro';
import InnerPageHeader from '../../components/InnerPageHeader.astro';
import { getProjects, getProjectImageUrls } from '../../lib/projects';

const base = import.meta.env.BASE_URL;
const projectImagesById: Record<string, string[]> = {};
for (const p of getProjects()) {
  projectImagesById[p.id] = getProjectImageUrls(p);
}
const projectImagesJson = JSON.stringify(projectImagesById);

const projects = getProjects()
  .slice()
  .sort((a, b) => {
    const yA = parseInt(String(a.year || ''), 10) || 0;
    const yB = parseInt(String(b.year || ''), 10) || 0;
    return yB - yA; // newest first, как при первой загрузке в скрипте
  });

function splitProjectTitle(project: { title?: string; shortTitle?: string }) {
  const full = String(project.title || '').trim();
  const short = String(project.shortTitle || '').trim();
  if (!short) return { short: full, tail: '' };
  const fullLower = full.toLowerCase();
  const shortLower = short.toLowerCase();
  if (fullLower.startsWith(shortLower)) {
    return { short, tail: full.slice(short.length) };
  }
  if (full === short) return { short, tail: '' };
  return { short, tail: ' ' + full };
}
---

<BaseLayout title="Index" variant="inner" bodyClass="page-index" hideHeader>
  <div class="inner-page">
    <div id="indexHoverScatter" class="index-hover-scatter" aria-hidden="true"></div>
    <div class="index2__grid">
      <InnerPageHeader activePage="index" />
      <div class="name index-labels-name">Name</div>
      <div class="type index-labels-type">Type</div>
      <button type="button" class="year index-labels-year year-sort-btn" id="yearSort" aria-label="Сортировка по году">Year</button>
      <div class="index-list-wrap">
        <div class="index-list" id="indexList">
          {projects.map((p) => {
            const titleParts = splitProjectTitle(p);
            return (
              <a href={`${base}project/${p.id}/`} class="index-list__row" data-year={p.year || ''} data-cover={p.cover || ''} data-project-id={p.id}>
                <span class="index-list__name">
                  <span class="index-list__name-short">{titleParts.short}</span><span class="index-list__name-tail">{titleParts.tail}</span>
                </span>
                <span class="index-list__type">{p.type || ''}</span>
                <span class="index-list__year">{p.year || ''}</span>
              </a>
            );
          })}
        </div>
        <div class="index-list-preview" id="indexListPreview" aria-hidden="true">
          <img id="indexListPreviewImg" alt="" />
        </div>
      </div>
      <div class="index-footer__schk"><a href="https://t.me/schtab_kvartira" target="_blank" rel="noopener noreferrer">SCHK</a></div>
      <p class="index-footer__text">The combination of robust classical typography with a clear vision of the path and experimental visualization is a true balance between chaotic trash art and an academic approach.</p>
      <div class="index-footer__name">Vasilii Aleev</div>
      <div class="index-footer__links"><a href="https://www.instagram.com/wazz4by" target="_blank" rel="noopener noreferrer">Ig</a><br/><a href="https://t.me/waz4by" target="_blank" rel="noopener noreferrer">Tg</a><br/><a href="https://www.behance.net/wazz4by/" target="_blank" rel="noopener noreferrer">Be</a></div>
    </div>
  </div>
  <script type="application/json" id="indexProjectImagesData" set:html={projectImagesJson} />
</BaseLayout>

<style>
  /* Index: 12 колонок, 4 ряда — шапка → Name/Type/Year → список → футер */
  :global(body.page-index .index2__grid) {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    grid-template-rows: auto auto 1fr auto;
    gap: 0 var(--grid-gutter);
    position: relative;
  }

  :global(body.page-index .inner-page) {
    position: relative;
  }
  :global(body.page-index .index2__grid .page-header) {
    grid-column: 1 / -1;
    grid-row: 1;
    z-index: 100;
  }
  :global(body.page-index .index2__grid .index-list-wrap) {
    grid-column: 1 / -1;
    grid-row: 3;
    position: relative;
    z-index: 0;
    padding-top: 0;
    padding-left: 0;
    padding-right: 0;
    min-height: 0;
  }
  :global(body.page-index .index2__grid .index-list) {
    position: relative;
    z-index: 0;
    padding-top: 0;
  }
  :global(body.page-index .index2__grid .index-list-preview) {
    position: absolute;
    left: calc(4 * (100% - 11 * var(--grid-gutter)) / 12 + 4 * var(--grid-gutter));
    width: calc(2 * (100% - 11 * var(--grid-gutter)) / 12 + var(--grid-gutter));
    max-height: 40vh;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    overflow: hidden;
    pointer-events: none;
    z-index: 0;
    opacity: 0;
  }
  :global(body.page-index .index2__grid .index-list-preview.index-list-preview--visible) {
    opacity: 1;
  }
  :global(body.page-index .index2__grid .index-list-preview img) {
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
  }

  /* Футер как на странице проекта: кол. 1 — SCHK, 7–11 — текст, 11 — имя, 12 — ссылки */
  :global(body.page-index .index2__grid .index-footer__schk) {
    grid-column: 1;
    grid-row: 4;
    margin-top: 50px;
    margin-bottom: 30px;
    font-family: 'SuisseIntl', sans-serif;
    font-size: 12px;
    font-weight: 500;
    color: black;
    line-height: 1;
  }
  :global(body.page-index .index2__grid .index-footer__schk a) {
    color: inherit;
    text-decoration: none;
  }
  :global(body.page-index .index2__grid .index-footer__text) {
    grid-column: 7 / 11;
    grid-row: 4;
    margin-top: 50px;
    margin-bottom: 30px;
    font-family: 'SuisseIntl', sans-serif;
    font-size: 12px;
    font-weight: 500;
    color: black;
    opacity: 1;
    line-height: 1;
  }
  :global(body.page-index .index2__grid .index-footer__name) {
    grid-column: 11;
    grid-row: 4;
    margin-top: 50px;
    margin-bottom: 30px;
    font-family: 'SuisseIntl', sans-serif;
    font-size: 16pt;
    font-weight: 500;
    color: black;
    line-height: 1;
  }
  :global(body.page-index .index2__grid .index-footer__links) {
    grid-column: 12;
    grid-row: 4;
    margin-top: 50px;
    margin-bottom: 30px;
    font-family: 'SuisseIntl', sans-serif;
    font-size: 16pt;
    font-weight: 500;
    color: black;
    text-align: right;
    line-height: 1;
  }

  /* Name, Type, Year — одна строка (row 2), разные колонки */
  :global(body.page-index .index2__grid .index-labels-name) {
    grid-column: 1;
    grid-row: 2;
    margin-top: 220px;
  }
  :global(body.page-index .index2__grid .index-labels-type) {
    grid-column: 7;
    grid-row: 2;
    margin-top: 220px;
  }
  :global(body.page-index .index2__grid .index-labels-year) {
    grid-column: 12;
    grid-row: 2;
    justify-self: end;
    margin-top: 220px;
  }

  .name, .type, .year {
    font-family: 'SuisseIntl', sans-serif;
    font-size: 12px;
    font-weight: 500;
    color: black;
    opacity: 1;
  }

  .year {
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    text-align: right;
  }
  .year:hover { opacity: 0.5; }

  :global(body.page-index .index-list) {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  /* 12 колонок как у страницы (Name 1, Type 7, Year 12) */
  :global(body.page-index .index-list__row) {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: 0 var(--grid-gutter);
    align-items: start;
    text-decoration: none;
    color:#B29893;
  }

  :global(body.page-index .index-list__row .index-list__name) { grid-column: 1 / 7; }
  :global(body.page-index .index-list__row .index-list__type) { grid-column: 7 / 12; }
  :global(body.page-index .index-list__row .index-list__year) { grid-column: 12; text-align: right; }

  :global(body.page-index .index-list__row:hover) {
    color: black;
  }
  :global(body.page-index .index-list__row:hover .index-list__name),
  :global(body.page-index .index-list__row:hover .index-list__type),
  :global(body.page-index .index-list__row:hover .index-list__year) {
    color: black;
    opacity: 1;
  }

  :global(body.page-index .index-list__name),
  :global(body.page-index .index-list__type),
  :global(body.page-index .index-list__year) {
    font-family: 'SuisseIntl', sans-serif;
    font-size: 24px;
    font-weight: 500;
    line-height: 75%;
    word-wrap: break-word;
    padding-bottom: 0;
  }

  :global(body.page-index .index-list__name) { text-align: left; }
  :global(body.page-index .index-list__name .index-list__name-tail) {
    opacity: 0.25;
    transition: opacity 0.05s ease;
  }
  :global(body.page-index .index-list__row:hover .index-list__name .index-list__name-tail) {
    opacity: 1;
  }
  :global(body.page-index .index-list__type) { text-align: left; }
  :global(body.page-index .index-list__year) { text-align: right; }

  :global(body.page-index .index-hover-scatter) {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }
  :global(body.page-index .index-hover-scatter img) {
    position: fixed;
    width: var(--index-hover-col-w, 120px);
    max-width: min(
      var(--index-hover-col-w, 120px),
      calc((2 * (100vw - 11 * var(--grid-gutter, 20px)) / 12) + var(--grid-gutter, 20px))
    );
    height: auto;
    max-height: 45vh;
    object-fit: contain;
    pointer-events: none;
    opacity: 0;
    animation: index-hover-float-in 0.22s ease forwards;
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.07);
  }
  @keyframes index-hover-float-in {
    from {
      opacity: 0;
      transform: scale(0.96);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }
</style>

<script define:vars={{ base }}>
  (function () {
    const list = document.getElementById('indexList');
    const yearBtn = document.getElementById('yearSort');
    const preview = document.getElementById('indexListPreview');
    const previewImg = document.getElementById('indexListPreviewImg');
    const scatterEl = document.getElementById('indexHoverScatter');
    const imagesDataEl = document.getElementById('indexProjectImagesData');
    if (!list || !yearBtn) return;

    let projectImagesMap = {};
    if (imagesDataEl && imagesDataEl.textContent) {
      try {
        projectImagesMap = JSON.parse(imagesDataEl.textContent) || {};
      } catch (e) {
        projectImagesMap = {};
      }
    }

    function twoColumnsWidthPx() {
      const root = document.documentElement;
      const gutter = parseFloat(getComputedStyle(root).getPropertyValue('--grid-gutter')) || 20;
      const w = root.clientWidth || window.innerWidth;
      const col = (w - 11 * gutter) / 12;
      return Math.max(120, 2 * col + gutter);
    }

    function shufflePick(arr, n) {
      const copy = arr.slice();
      for (let i = copy.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        const t = copy[i];
        copy[i] = copy[j];
        copy[j] = t;
      }
      return copy.slice(0, n);
    }

    function randomInt(a, b) {
      return a + Math.floor(Math.random() * (b - a + 1));
    }

    function clearScatter() {
      if (scatterEl) scatterEl.innerHTML = '';
    }

    function showScatter(projectId) {
      if (!scatterEl) return;
      clearScatter();
      const urls = projectImagesMap[projectId];
      if (!urls || !urls.length) return;
      const n = Math.min(urls.length, randomInt(3, 6));
      const count = Math.max(1, n);
      const picked = shufflePick(urls, count);
      const colW = twoColumnsWidthPx();
      document.documentElement.style.setProperty('--index-hover-col-w', colW + 'px');
      const vw = window.innerWidth;
      const vh = window.innerHeight;
      const pad = 10;
      const maxH = Math.min(vh * 0.45, colW * 3);
      const rangeX = Math.max(0, vw - colW - 2 * pad);
      const rangeY = Math.max(0, vh - maxH - 2 * pad);
      const baseUrl = base.endsWith('/') ? base : base + '/';
      picked.forEach(function (src) {
        const img = document.createElement('img');
        const path = String(src).replace(/^\//, '');
        img.src = /^https?:/i.test(path) ? path : baseUrl + path;
        img.alt = '';
        img.loading = 'eager';
        img.style.left = pad + Math.random() * rangeX + 'px';
        img.style.top = pad + Math.random() * rangeY + 'px';
        scatterEl.appendChild(img);
      });
    }

    let newestFirst = true;

    function resolveCoverUrl(cover) {
      const c = (cover || '').trim();
      if (!c) return '';
      if (c.startsWith('http')) return c;
      return (base.endsWith('/') ? base : base + '/') + c.replace(/^\//, '');
    }

    function showPreview(url, row) {
      if (!preview || !previewImg) return;
      if (url && row) {
        const wrap = list.parentElement;
        const newTop = wrap ? (row.getBoundingClientRect().top - wrap.getBoundingClientRect().top + wrap.scrollTop) + 'px' : '';
        preview.style.top = newTop;
        previewImg.src = url;
        preview.classList.add('index-list-preview--visible');
        preview.setAttribute('aria-hidden', 'false');
      } else {
        preview.classList.remove('index-list-preview--visible');
        preview.setAttribute('aria-hidden', 'true');
        preview.style.top = '';
        previewImg.removeAttribute('src');
      }
    }

    list.querySelectorAll('.index-list__row').forEach(function (row) {
      row.addEventListener('mouseenter', function () {
        const cover = row.dataset.cover;
        showPreview(resolveCoverUrl(cover), row);
        const pid = row.dataset.projectId;
        if (pid) showScatter(pid);
      });
      row.addEventListener('mouseleave', function () {
        showPreview('');
        clearScatter();
      });
    });

    function sortRows() {
      const rows = Array.from(list.querySelectorAll('.index-list__row'));
      rows.sort(function (a, b) {
        const yA = parseInt(a.dataset.year, 10) || 0;
        const yB = parseInt(b.dataset.year, 10) || 0;
        if (newestFirst) return yB - yA;
        return yA - yB;
      });
      rows.forEach(function (row) { list.appendChild(row); });
    }

    yearBtn.addEventListener('click', function () {
      newestFirst = !newestFirst;
      sortRows();
    });

    sortRows();
  })();
</script>
