---
import BaseLayout from '../layouts/BaseLayout.astro';
import MediaCard from '../components/MediaCard.astro';
import { getHomeMediaCards } from '../lib/homeMediaCards';
import { getProjects } from '../lib/projects';

const base = import.meta.env.BASE_URL;
const logoSrc = `${base}images/main/Vasilii%20Aleev.svg`;

const homeMediaCards = getHomeMediaCards();
const projects = getProjects();
const projectById = new Map(projects.map((p) => [p.id, p.title]));

function projectTitleFromHref(href?: string): string {
  const value = typeof href === 'string' ? href.trim() : '';
  if (!value) return '';
  const match = value.match(/\/project\/([^/]+)\/?$/);
  if (!match) return '';
  const id = decodeURIComponent(match[1]);
  return projectById.get(id) || '';
}

function gridColumnForCard(card: { size?: 'normal' | 'wide'; edge?: 'auto' | 'left' | 'right' }): string {
  const isWide = card.size === 'wide';
  if (card.edge === 'left') return isWide ? '1 / span 6' : '1 / span 4';
  if (card.edge === 'right') return isWide ? '7 / span 6' : '9 / span 4';
  return isWide ? 'span 6' : 'span 4';
}
---

<BaseLayout title="Home" variant="home" hideHeader>
  <main class="home-page">
    <h1 class="sr-only">Vasilii Aleev - Portfolio</h1>

    <nav class="home-hero" aria-label="Main navigation">
      <div class="home-hero__row">
        <div class="home-hero__side home-hero__side--left">
          <a href={`${base}index/`} class="home-hero__link">Index</a>
          <a href={`${base}research/`} class="home-hero__link">Research</a>
        </div>
        <a href={base === '/' ? '/' : base} class="home-hero__logo-link" aria-label="Vasilii Aleev">
          <img
            class="home-hero__logo"
            src={logoSrc}
            width="155"
            height="22"
            alt=""
          />
        </a>
        <div class="home-hero__side home-hero__side--right">
          <a href={`${base}info/`} class="home-hero__link">Info</a>
          <a
            href="https://t.me/schtab_kvartira"
            target="_blank"
            rel="noopener noreferrer"
            class="home-hero__link"
          >schk</a>
        </div>
      </div>
    </nav>

    <section class="home-media-showcase" aria-label="Media Card Showcase">
      <div class="home-media-grid home-media-grid--mixed">
        {homeMediaCards.map((card) => (
          <div class="home-media-grid__item" style={`--home-card-col: ${gridColumnForCard(card)};`}>
            <MediaCard
              href={card.href}
              src={card.src}
              alt={card.alt || ''}
              ratio={card.ratio || 'aspect-16-9'}
              as={card.as || 'image'}
              loading={card.loading || 'lazy'}
              title={card.title}
              caption={card.caption}
              cursorLabel={card.cursorLabel || projectTitleFromHref(card.href)}
              className={card.className}
              videoPoster={card.videoPoster}
            />
          </div>
        ))}
      </div>
    </section>

    <footer class="home-footer">
      <div class="home-footer__grid">
        <div class="index-footer__schk"><a href="https://t.me/schtab_kvartira" target="_blank" rel="noopener noreferrer">SCHK</a></div>
        <p class="index-footer__text">The combination of robust classical typography with a clear vision of the path and experimental visualization is a true balance between chaotic trash art and an academic approach.</p>
        <div class="index-footer__name">Vasilii Aleev</div>
        <div class="index-footer__links"><a href="https://www.instagram.com/wazz4by" target="_blank" rel="noopener noreferrer">Ig</a><br/><a href="https://t.me/waz4by" target="_blank" rel="noopener noreferrer">Tg</a><br/><a href="https://www.behance.net/wazz4by/" target="_blank" rel="noopener noreferrer">Be</a></div>
      </div>
    </footer>
  </main>
</BaseLayout>

<style>
  :global(body.is-home) {
    overflow-x: clip;
  }

  .home-page {
    width: 100%;
    max-width: 100%;
    min-height: 100vh;
    position: relative;
    background: #FBFBFB;
    --home-logo-width: 155px;
    --home-logo-height: 22px;
    --home-nav-gap: 40px;
    --home-intro-height: 100vh;
  }

  /* Как .page-header: difference на контейнере + белый цвет */
  .home-hero {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 var(--grid-margin);
    pointer-events: none;
    mix-blend-mode: difference;
    color: #fff;
    background: transparent;
  }

  .home-hero__row {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
    align-items: center;
    width: 100%;
    max-width: 100%;
    min-width: 0;
    column-gap: var(--home-nav-gap);
    pointer-events: auto;
    box-sizing: border-box;
  }

  .home-hero__side {
    display: flex;
    align-items: center;
    gap: var(--home-nav-gap);
    min-width: 0;
  }

  .home-hero__side--left {
    justify-content: flex-end;
  }

  .home-hero__side--right {
    justify-content: flex-start;
  }

  .home-hero__logo-link {
    grid-column: 2;
    justify-self: center;
    display: block;
    line-height: 0;
    text-decoration: none;
    color: inherit;
  }

  .home-hero__logo {
    display: block;
    width: var(--home-logo-width);
    height: var(--home-logo-height);
    max-width: none;
    filter: brightness(0) invert(1);
  }

  .home-hero a {
    color: inherit;
    text-decoration: none;
  }

  .home-hero__link {
    font-family: 'SuisseIntl', sans-serif;
    font-weight: 500;
    font-size: 14px;
    line-height: 1;
    opacity: 0.3;
    white-space: nowrap;
    transition: opacity 0.2s, font-weight 0.2s;
  }

  .home-hero__link:hover {
    opacity: 1;
    font-weight: 700;
  }

  @media (max-width: 900px) {
    .home-page {
      --home-nav-gap: 28px;
    }
  }

  @media (max-width: 680px) {
    .home-page {
      --home-nav-gap: 20px;
    }

    .home-hero {
      padding: 0 16px;
    }

    .home-hero__row {
      grid-template-columns: 1fr;
      row-gap: 20px;
      justify-items: center;
    }

    .home-hero__side--left,
    .home-hero__side--right {
      justify-content: center;
      width: 100%;
    }

    .home-hero__logo-link {
      grid-column: 1;
      grid-row: 2;
    }

    .home-hero__side--left {
      grid-row: 1;
    }

    .home-hero__side--right {
      grid-row: 3;
    }

    .home-hero__link {
      font-size: 12px;
    }
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }

  :global(body.is-home .home-media-showcase) {
    width: 100vw;
    max-width: 100%;
    margin-left: calc(50% - 50vw);
    padding: var(--home-intro-height) 0 0;
    box-sizing: border-box;
    overflow-x: clip;
  }

  :global(body.is-home .home-media-grid) {
    display: grid;
    width: 100%;
    min-width: 0;
    max-width: 100%;
    gap: 0;
  }

  :global(body.is-home .home-media-grid--single) {
    grid-template-columns: 1fr;
  }

  :global(body.is-home .home-media-grid--two) {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  :global(body.is-home .home-media-grid--three) {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  :global(body.is-home .home-media-grid--mixed) {
    grid-template-columns: repeat(12, minmax(0, 1fr));
  }

  :global(body.is-home .home-media-grid__item) {
    min-width: 0;
    grid-column: var(--home-card-col, span 4);
  }

  @media (max-width: 980px) {
    :global(body.is-home .home-media-grid--mixed) {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
    :global(body.is-home .home-media-grid__item) {
      grid-column: span 1;
    }
  }

  @media (max-width: 640px) {
    :global(body.is-home .home-media-showcase) {
      padding-top: var(--home-intro-height);
    }
    :global(body.is-home .home-media-grid--mixed) {
      grid-template-columns: 1fr;
      gap: 0;
    }
  }

  /* Футер как на странице проекта: кол. 1 — SCHK, 7–11 — текст, 11 — имя, 12 — ссылки */
  :global(body.is-home .home-footer) {
    margin-top: 50px;
    width: 100%;
    box-sizing: border-box;
  }

  :global(body.is-home .home-footer__grid) {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: 0 var(--grid-gutter);
    padding: 0 var(--grid-margin);
    max-width: 100%;
    box-sizing: border-box;
  }

  :global(body.is-home .home-footer__grid .index-footer__schk) {
    grid-column: 1;
    grid-row: 1;
    margin-top: 50px;
    margin-bottom: 30px;
    font-family: 'SuisseIntl', sans-serif;
    font-size: 12px;
    font-weight: 500;
    color: black;
    line-height: 1;
  }

  :global(body.is-home .home-footer__grid .index-footer__schk a) {
    color: inherit;
    text-decoration: none;
  }

  :global(body.is-home .home-footer__grid .index-footer__text) {
    grid-column: 7 / 11;
    grid-row: 1;
    margin: 0;
    margin-top: 50px;
    margin-bottom: 30px;
    font-family: 'SuisseIntl', sans-serif;
    font-size: 12px;
    font-weight: 500;
    color: black;
    line-height: 1;
    min-width: 0;
    overflow-wrap: break-word;
  }

  :global(body.is-home .home-footer__grid .index-footer__name) {
    grid-column: 11;
    grid-row: 1;
    margin: 0;
    margin-top: 50px;
    margin-bottom: 30px;
    font-family: 'SuisseIntl', sans-serif;
    font-size: 16pt;
    font-weight: 500;
    color: black;
    line-height: 1;
  }

  :global(body.is-home .home-footer__grid .index-footer__links) {
    grid-column: 12;
    grid-row: 1;
    margin: 0;
    margin-top: 50px;
    margin-bottom: 30px;
    font-family: 'SuisseIntl', sans-serif;
    font-size: 16pt;
    font-weight: 500;
    color: black;
    text-align: right;
    line-height: 1;
  }

  :global(body.is-home .home-footer__grid .index-footer__links a),
  :global(body.is-home .home-footer__grid .index-footer__schk a) {
    color: inherit;
  }

  @media (max-width: 900px) {
    :global(body.is-home .home-footer__grid) {
      grid-template-columns: 1fr;
      gap: 1.25rem 0;
      padding: 0 var(--grid-margin);
    }

    :global(body.is-home .home-footer__grid .index-footer__schk),
    :global(body.is-home .home-footer__grid .index-footer__text),
    :global(body.is-home .home-footer__grid .index-footer__name),
    :global(body.is-home .home-footer__grid .index-footer__links) {
      grid-column: 1;
      grid-row: auto;
      margin: 0;
      justify-self: center;
      text-align: center;
      max-width: min(100%, 22rem);
    }

    :global(body.is-home .home-footer__grid .index-footer__schk) {
      margin-top: 50px;
    }

    :global(body.is-home .home-footer__grid .index-footer__links) {
      margin-bottom: 30px;
    }
  }
</style>
