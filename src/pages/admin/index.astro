---
import AdminLayout from '../../layouts/AdminLayout.astro';
const base = import.meta.env.BASE_URL;
---

<AdminLayout title="Админка — Проекты">
  <div id="admin-root">
    <div id="gate" class="gate">
      <h1>Вход в админку</h1>
      <p>Введите пароль. По умолчанию: <code>admin</code>.</p>
      <input type="password" id="password" placeholder="Пароль" autocomplete="current-password" />
      <button type="button" id="loginBtn" class="primary">Войти</button>
      <p id="gateError" class="error" style="display:none;"></p>
    </div>

    <div id="app" style="display:none;">
      <h1>Управление проектами</h1>
      <p id="loadStatus" class="status">Загрузка…</p>
      <div id="adminNav" style="display:flex;flex-wrap:wrap;gap:0.5rem;margin:0.75rem 0 1rem;">
        <button type="button" class="secondary admin-nav-btn" data-pane="projectsPane">Проекты</button>
        <button type="button" class="secondary admin-nav-btn" data-pane="homeCardsPane">Главная: Media Cards</button>
        <button type="button" class="secondary admin-nav-btn" data-pane="researchCardsPane">Research</button>
        <button type="button" class="secondary admin-nav-btn" data-pane="githubPane">GitHub</button>
        <button type="button" class="secondary admin-nav-btn" data-pane="backupPane">Резервная копия</button>
      </div>

      <section class="admin-section admin-pane" id="projectsPane">
        <h2>Список проектов</h2>
        <ul class="project-list" id="projectList"></ul>
        <p class="mb-2"><a href={`${base}admin/add/`}>+ Добавить проект</a></p>
      </section>

      <section class="admin-section admin-pane" id="homeCardsPane">
        <h2>Фото на главной (Media Cards)</h2>
        <p class="admin-hint">Управление карточками на главной странице. Можно загружать фото в репозиторий (папка <code>public/images/main</code>) и сразу подставлять путь в карточку. Для режима <code>vimeo</code> вставляйте iframe/embed или ссылку Vimeo, для <code>kinescope</code> — iframe/embed или ссылку Kinescope.</p>
        <p id="homeMediaCardsLoadStatus" class="status">Загрузка…</p>
        <div id="homeMediaCardsEditor"></div>
        <div style="margin-top:1rem;">
          <button type="button" id="addHomeMediaCardBtn" class="secondary">+ Добавить карточку</button>
          <button type="button" id="saveHomeMediaCardsToGitHubBtn" class="primary" style="margin-left:0.5rem;">Сохранить карточки в GitHub</button>
          <button type="button" id="downloadHomeMediaCardsBtn" class="secondary" style="margin-left:0.5rem;">Скачать home-media-cards.json</button>
        </div>
        <p id="homeMediaCardsGhStatus" class="status"></p>
      </section>

      <section class="admin-section admin-section--wide admin-pane" id="researchCardsPane">
        <h2>Карточки Research</h2>
        <p class="admin-hint">Квадратные контейнеры на вкладке Research. Для режима <code>image</code> можно загружать только <code>jpg</code>, <code>png</code> и <code>gif</code>. Для режима <code>kinescope</code> вставляйте ссылку или iframe embed. Карточки сортируются по номеру: больший номер выше.</p>
        <p id="researchCardsLoadStatus" class="status">Загрузка…</p>
        <div style="display:flex;gap:0.5rem;flex-wrap:wrap;align-items:center;margin-bottom:0.75rem;">
          <button type="button" id="addResearchCardBtn" class="secondary">+ Добавить карточку</button>
          <button type="button" id="researchViewListBtn" class="primary">Список</button>
          <button type="button" id="researchViewGridBtn" class="secondary">Сетка 5</button>
          <button type="button" id="researchViewPreviewBtn" class="secondary">Мини-превью</button>
          <label for="researchCardScaleRange" style="margin:0 0 0 0.5rem;font-weight:500;">Масштаб карточек</label>
          <input type="range" id="researchCardScaleRange" min="70" max="140" step="5" value="100" style="width:170px;margin:0;" />
          <span id="researchCardScaleValue" style="min-width:3ch;">100%</span>
        </div>
        <div id="researchCardsEditor"></div>
        <div style="margin-top:1rem;">
          <button type="button" id="saveResearchCardsToGitHubBtn" class="primary">Сохранить карточки в GitHub</button>
          <button type="button" id="downloadResearchCardsBtn" class="secondary" style="margin-left:0.5rem;">Скачать research-cards.json</button>
        </div>
        <p id="researchCardsGhStatus" class="status"></p>
      </section>

      <section class="admin-section admin-pane" id="githubPane">
        <h2>Сохранение в GitHub</h2>
        <p>Чтобы изменения автоматически попадали в репозиторий, укажите репозиторий и токен. После нажатия «Сохранить в GitHub» файл <code>public/data/projects.json</code> будет закоммичен в ветку <code>main</code>; деплой выполнит GitHub Actions.</p>
        <label>Репозиторий (owner/repo)</label>
        <input type="text" id="ghRepo" placeholder="wazz4by/wazz4by.github.io" />
        <label>GitHub Personal Access Token (права repo)</label>
        <input type="password" id="ghToken" placeholder="ghp_xxxx…" autocomplete="off" />
        <button type="button" id="saveToGitHubBtn" class="primary">Сохранить в GitHub</button>
        <p id="ghStatus" class="status"></p>
      </section>

      <section class="admin-section admin-pane" id="backupPane">
        <h2>Резервная копия</h2>
        <p>Скачайте <code>projects.json</code> и при необходимости замените им файл в репозитории вручную.</p>
        <button type="button" id="downloadBtn" class="secondary">Скачать projects.json</button>
      </section>
    </div>
  </div>

  <script define:vars={{ base }}>
    (function () {
      const STORAGE_KEY = 'admin_authed';
      const PASSWORD = 'admin';
      const REPO_KEY = 'admin_gh_repo';

      const gate = document.getElementById('gate');
      const app = document.getElementById('app');
      const passwordInput = document.getElementById('password');
      const gateError = document.getElementById('gateError');
      const loginBtn = document.getElementById('loginBtn');

      function checkAuth() {
        if (sessionStorage.getItem(STORAGE_KEY) === '1') {
          gate.style.display = 'none';
          app.style.display = 'block';
          initApp();
          return;
        }
        gate.style.display = 'block';
        app.style.display = 'none';
      }

      loginBtn.addEventListener('click', function () {
        gateError.style.display = 'none';
        if (passwordInput.value === PASSWORD) {
          sessionStorage.setItem(STORAGE_KEY, '1');
          checkAuth();
        } else {
          gateError.textContent = 'Неверный пароль.';
          gateError.style.display = 'block';
        }
      });

      passwordInput.addEventListener('keydown', function (e) {
        if (e.key === 'Enter') loginBtn.click();
      });

      document.querySelector('.admin-page__back')?.addEventListener('click', function(){});
      const ADMIN_PANES = ['projectsPane', 'homeCardsPane', 'researchCardsPane', 'githubPane', 'backupPane'];
      let adminNavInitialized = false;

      function setActivePane(paneId) {
        const target = ADMIN_PANES.includes(paneId) ? paneId : 'projectsPane';
        ADMIN_PANES.forEach(function (id) {
          const pane = document.getElementById(id);
          if (pane) pane.style.display = id === target ? 'block' : 'none';
        });
        document.querySelectorAll('.admin-nav-btn').forEach(function (btn) {
          const isActive = btn.getAttribute('data-pane') === target;
          btn.className = isActive ? 'primary admin-nav-btn' : 'secondary admin-nav-btn';
        });
      }

      function initAdminNav() {
        if (adminNavInitialized) return;
        adminNavInitialized = true;
        document.querySelectorAll('.admin-nav-btn').forEach(function (btn) {
          btn.addEventListener('click', function () {
            setActivePane(this.getAttribute('data-pane') || 'projectsPane');
          });
        });
      }

      let projects = [];
      let homeMediaCards = [];
      let researchCards = [];
      let researchCardsView = 'list';
      let researchCardsScale = 100;
      let draggedResearchIndex = null;

      const HOME_MEDIA_RATIOS = [
        'aspect-16-9',
        'aspect-4-5',
        'aspect-3-4',
        'aspect-1-1',
        'aspect-original',
        'aspect-free'
      ];

      function dataUrl() {
        const path = window.location.pathname;
        const basePath = path.replace(/\/admin\/?.*$/, '') || '/';
        return (basePath.endsWith('/') ? basePath : basePath + '/') + 'data/projects.json';
      }

      function dataUrlHomeMediaCards() {
        const path = window.location.pathname;
        const basePath = path.replace(/\/admin\/?.*$/, '') || '/';
        return (basePath.endsWith('/') ? basePath : basePath + '/') + 'data/home-media-cards.json';
      }

      function dataUrlResearchCards() {
        const path = window.location.pathname;
        const basePath = path.replace(/\/admin\/?.*$/, '') || '/';
        return (basePath.endsWith('/') ? basePath : basePath + '/') + 'data/research-cards.json';
      }

      async function loadProjects() {
        const status = document.getElementById('loadStatus');
        try {
          const res = await fetch(dataUrl(), { cache: 'no-store' });
          if (!res.ok) throw new Error(res.statusText);
          projects = await res.json();
          if (!Array.isArray(projects)) projects = [];
          const newProjectRaw = sessionStorage.getItem('admin_new_project');
          if (newProjectRaw) {
            try {
              const newProject = JSON.parse(newProjectRaw);
              if (newProject.id && !projects.find(p => p.id === newProject.id)) projects.push(newProject);
              sessionStorage.removeItem('admin_new_project');
            } catch (_) {}
          }
          const editedRaw = sessionStorage.getItem('admin_edited_projects');
          if (editedRaw) {
            try {
              const edited = JSON.parse(editedRaw);
              Object.keys(edited).forEach(function (id) {
                const idx = projects.findIndex(p => p.id === id);
                if (idx >= 0) projects[idx] = edited[id];
              });
            } catch (_) {}
          }
          status.textContent = 'Загружено проектов: ' + projects.length;
          status.className = 'status ok';
          renderProjectList();
          restoreGhRepo();
          return projects;
        } catch (e) {
          status.textContent = 'Ошибка загрузки: ' + e.message;
          status.className = 'status err';
          projects = [];
          return [];
        }
      }

      function getBase() {
        const path = window.location.pathname;
        const basePath = path.replace(/\/admin\/?.*$/, '') || '/';
        return basePath.endsWith('/') ? basePath : basePath + '/';
      }

      function renderProjectList() {
        const list = document.getElementById('projectList');
        list.innerHTML = '';
        projects.forEach(function (p) {
          const li = document.createElement('li');
          const base = getBase();
          li.innerHTML = '<span>' + (p.title || p.id) + '</span><span><a href="' + base + 'admin/edit/?id=' + encodeURIComponent(p.id) + '">Редактировать</a> <button type="button" class="danger delete-project" data-id="' + p.id + '" style="margin-left:0.5rem;padding:0.25rem 0.5rem;font-size:0.85rem;">Удалить</button></span>';
          list.appendChild(li);
        });
        list.querySelectorAll('.delete-project').forEach(function (btn) {
          btn.addEventListener('click', function () {
            const id = this.getAttribute('data-id');
            const p = projects.find(function (x) { return x.id === id; });
            if (!p || !confirm('Удалить проект «' + (p.title || id) + '»?')) return;
            projects = projects.filter(function (x) { return x.id !== id; });
            renderProjectList();
            document.getElementById('loadStatus').textContent = 'Проект удалён из списка. Нажмите «Сохранить в GitHub» или скачайте projects.json.';
          });
        });
      }

      function restoreGhRepo() {
        try {
          const saved = sessionStorage.getItem(REPO_KEY);
          if (saved && document.getElementById('ghRepo')) document.getElementById('ghRepo').value = saved;
        } catch (_) {}
      }

      function normalizeHomeMediaCard(card) {
        const c = card || {};
        const ratio = HOME_MEDIA_RATIOS.includes(c.ratio) ? c.ratio : 'aspect-16-9';
        return {
          href: typeof c.href === 'string' ? c.href : '/index/',
          src: typeof c.src === 'string' ? c.src : '',
          alt: typeof c.alt === 'string' ? c.alt : '',
          ratio: ratio,
          as: c.as === 'video' || c.as === 'vimeo' || c.as === 'kinescope' ? c.as : 'image',
          size: c.size === 'wide' ? 'wide' : 'normal',
          edge: c.edge === 'left' || c.edge === 'right' ? c.edge : 'auto'
        };
      }

      function normalizeResearchCard(card, fallbackNumber) {
        const c = card || {};
        const parsedNumber = Number(c.number);
        const rawDate = typeof c.date === 'string' ? c.date : '';
        const m = rawDate.trim().match(/^(\d{1,2})[.\-/](\d{4})$/);
        const normalizedDate = m ? String(m[1]).padStart(2, '0') + '.' + m[2] : '';
        return {
          number: Number.isFinite(parsedNumber) ? Math.max(0, Math.round(parsedNumber)) : fallbackNumber,
          src: typeof c.src === 'string' ? c.src : '',
          alt: typeof c.alt === 'string' ? c.alt : '',
          as: c.as === 'kinescope' ? 'kinescope' : 'image',
          caption: typeof c.caption === 'string' ? c.caption : '',
          date: normalizedDate
        };
      }

      function sortResearchCards() {
        researchCards.sort(function (a, b) {
          return Number(b.number || 0) - Number(a.number || 0);
        });
      }

      function reindexResearchCards() {
        const total = researchCards.length;
        researchCards.forEach(function (card, index) {
          card.number = total - index;
        });
      }

      function moveResearchCard(fromIndex, toIndex) {
        if (!Number.isFinite(fromIndex) || !Number.isFinite(toIndex)) return;
        if (fromIndex < 0 || toIndex < 0) return;
        if (fromIndex >= researchCards.length || toIndex >= researchCards.length) return;
        if (fromIndex === toIndex) return;
        const moved = researchCards.splice(fromIndex, 1)[0];
        researchCards.splice(toIndex, 0, moved);
        reindexResearchCards();
        renderResearchCardsEditor();
        const status = document.getElementById('researchCardsLoadStatus');
        if (status) status.textContent = 'Порядок обновлён. Карточек: ' + researchCards.length;
      }

      function syncResearchViewButtons() {
        const listBtn = document.getElementById('researchViewListBtn');
        const gridBtn = document.getElementById('researchViewGridBtn');
        const previewBtn = document.getElementById('researchViewPreviewBtn');
        if (listBtn) listBtn.className = researchCardsView === 'list' ? 'primary' : 'secondary';
        if (gridBtn) gridBtn.className = researchCardsView === 'grid' ? 'primary' : 'secondary';
        if (previewBtn) previewBtn.className = researchCardsView === 'preview' ? 'primary' : 'secondary';
      }

      function syncResearchScaleUi() {
        const range = document.getElementById('researchCardScaleRange');
        const label = document.getElementById('researchCardScaleValue');
        if (range) range.value = String(researchCardsScale);
        if (label) label.textContent = String(researchCardsScale) + '%';
      }

      async function loadHomeMediaCards() {
        const status = document.getElementById('homeMediaCardsLoadStatus');
        try {
          const res = await fetch(dataUrlHomeMediaCards(), { cache: 'no-store' });
          if (!res.ok) throw new Error(res.statusText);
          const data = await res.json();
          const arr = Array.isArray(data) ? data : data.cards;
          homeMediaCards = Array.isArray(arr) ? arr.slice(0, 30).map(normalizeHomeMediaCard) : [];
          status.textContent = 'Загружено карточек: ' + homeMediaCards.length;
          status.className = 'status ok';
          renderHomeMediaCardsEditor();
          return homeMediaCards;
        } catch (e) {
          homeMediaCards = [];
          status.textContent = 'Файл не найден или пустой. Добавьте карточки.';
          status.className = 'status';
          renderHomeMediaCardsEditor();
          return homeMediaCards;
        }
      }

      async function loadResearchCards() {
        const status = document.getElementById('researchCardsLoadStatus');
        try {
          const res = await fetch(dataUrlResearchCards(), { cache: 'no-store' });
          if (!res.ok) throw new Error(res.statusText);
          const data = await res.json();
          const arr = Array.isArray(data) ? data : data.cards;
          researchCards = Array.isArray(arr)
            ? arr.slice(0, 100).map(function (card, i) { return normalizeResearchCard(card, i + 1); })
            : [];
          sortResearchCards();
          status.textContent = 'Загружено карточек: ' + researchCards.length;
          status.className = 'status ok';
          renderResearchCardsEditor();
          return researchCards;
        } catch (e) {
          researchCards = [];
          status.textContent = 'Файл не найден или пустой. Добавьте карточки.';
          status.className = 'status';
          renderResearchCardsEditor();
          return researchCards;
        }
      }

      function esc(s) {
        return String(s || '')
          .replace(/&/g, '&amp;')
          .replace(/"/g, '&quot;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;');
      }

      function extractIframeSrc(raw) {
        const s = String(raw || '').trim();
        const m = s.match(/<iframe[\s\S]*?src=["']([^"']+)["']/i);
        if (m && m[1]) return m[1].trim();
        return s;
      }

      function getVimeoEmbedUrl(raw) {
        const s = extractIframeSrc(raw);
        if (!s) return '';
        const direct = s.match(/player\.vimeo\.com\/video\/(\d+)/);
        if (direct) return s;
        const page = s.match(/vimeo\.com\/(?:video\/)?(\d+)/);
        if (page) return 'https://player.vimeo.com/video/' + page[1] + '?background=1&autoplay=1&loop=1&muted=1';
        return s;
      }

      function getKinescopeEmbedUrl(raw) {
        const s = extractIframeSrc(raw);
        if (!s) return '';
        if (/kinescope\.(io|ru)\/embed\//.test(s)) return s;
        const m = s.match(/https?:\/\/(?:kinescope\.(?:io|ru))\/([^/?#]+)/);
        if (m && m[1]) return 'https://kinescope.io/embed/' + m[1] + '?autoplay=1&muted=1';
        return s;
      }

      function renderHomeMediaCardsEditor() {
        const container = document.getElementById('homeMediaCardsEditor');
        if (!container) return;
        container.innerHTML = '';

        function getHomeCardPreviewHtml(card) {
          const src = (card && typeof card.src === 'string') ? card.src : '';
          const as = (card && (card.as === 'video' || card.as === 'vimeo' || card.as === 'kinescope')) ? card.as : 'image';
          if (!src) return '<span style="font-size:12px;color:#666;">Превью появится после заполнения src</span>';
          if (as === 'vimeo') {
            return '<iframe src="' + esc(getVimeoEmbedUrl(src)) + '" frameborder="0" allow="autoplay; fullscreen; picture-in-picture" allowfullscreen style="width:100%;height:220px;display:block;border:0;"></iframe>';
          }
          if (as === 'kinescope') {
            return '<iframe src="' + esc(getKinescopeEmbedUrl(src)) + '" frameborder="0" allow="autoplay; fullscreen; picture-in-picture" allowfullscreen style="width:100%;height:220px;display:block;border:0;"></iframe>';
          }
          if (as === 'video') {
            return '<video src="' + esc(src) + '" muted playsinline preload="metadata" style="width:100%;max-height:220px;display:block;"></video>';
          }
          return '<img src="' + esc(src) + '" alt="" style="width:100%;max-height:220px;object-fit:contain;display:block;" />';
        }

        function updateHomeCardPreview(i) {
          const preview = container.querySelector('.home-card-preview[data-i="' + i + '"]');
          if (!preview) return;
          preview.innerHTML = getHomeCardPreviewHtml(homeMediaCards[i] || {});
        }

        homeMediaCards.forEach(function (card, i) {
          const item = normalizeHomeMediaCard(card);
          const row = document.createElement('div');
          row.style.cssText = 'margin-bottom:1rem;padding:1rem;border:1px solid #ddd;border-radius:6px;';
          row.innerHTML =
            '<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:0.75rem;">' +
              '<strong>Карточка ' + (i + 1) + '</strong>' +
              '<div style="display:flex;gap:0.4rem;align-items:center;">' +
                '<button type="button" class="secondary move-home-card-up" data-i="' + i + '" style="padding:0.25rem 0.5rem;font-size:0.85rem;">↑</button>' +
                '<button type="button" class="secondary move-home-card-down" data-i="' + i + '" style="padding:0.25rem 0.5rem;font-size:0.85rem;">↓</button>' +
                '<button type="button" class="danger delete-home-card" data-i="' + i + '" style="padding:0.25rem 0.5rem;font-size:0.85rem;">Удалить</button>' +
              '</div>' +
            '</div>' +
            '<div style="display:grid;gap:0.5rem;">' +
              '<label>Источник (src)</label>' +
              '<input type="text" class="home-card-src" data-i="' + i + '" value="' + esc(item.src) + '" placeholder="/images/main/photo.jpg" />' +
              '<div style="display:flex;gap:0.5rem;flex-wrap:wrap;align-items:center;">' +
                '<button type="button" class="secondary upload-home-card-image" data-i="' + i + '">Загрузить фото в GitHub</button>' +
                '<input type="file" class="home-card-file" data-i="' + i + '" accept="image/*" style="display:none;" />' +
              '</div>' +
              '<label>Ссылка (href)</label>' +
              '<input type="text" class="home-card-href" data-i="' + i + '" value="' + esc(item.href) + '" placeholder="/index/" />' +
              '<label>Alt</label>' +
              '<input type="text" class="home-card-alt" data-i="' + i + '" value="' + esc(item.alt) + '" placeholder="Описание изображения" />' +
              '<div style="display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:0.5rem;">' +
                '<div><label>Режим</label><select class="home-card-as" data-i="' + i + '"><option value="image"' + (item.as === 'image' ? ' selected' : '') + '>image</option><option value="video"' + (item.as === 'video' ? ' selected' : '') + '>video-file</option><option value="vimeo"' + (item.as === 'vimeo' ? ' selected' : '') + '>vimeo</option><option value="kinescope"' + (item.as === 'kinescope' ? ' selected' : '') + '>kinescope</option></select></div>' +
                '<div><label>Размер в сетке</label><select class="home-card-size" data-i="' + i + '"><option value="normal"' + (item.size === 'normal' ? ' selected' : '') + '>normal</option><option value="wide"' + (item.size === 'wide' ? ' selected' : '') + '>wide</option></select></div>' +
                '<div><label>Край</label><select class="home-card-edge" data-i="' + i + '"><option value="auto"' + (item.edge === 'auto' ? ' selected' : '') + '>auto</option><option value="left"' + (item.edge === 'left' ? ' selected' : '') + '>left</option><option value="right"' + (item.edge === 'right' ? ' selected' : '') + '>right</option></select></div>' +
              '</div>' +
              '<div><label>Пропорция</label><select class="home-card-ratio" data-i="' + i + '">' +
                HOME_MEDIA_RATIOS.map(function (r) {
                  return '<option value="' + r + '"' + (item.ratio === r ? ' selected' : '') + '>' + r + '</option>';
                }).join('') +
              '</select></div>' +
              '<div class="home-card-preview" data-i="' + i + '" style="margin-top:0.25rem;border:1px solid #eee;background:#f8f8f8;min-height:80px;display:flex;align-items:center;justify-content:center;overflow:hidden;">' +
                getHomeCardPreviewHtml(item) +
              '</div>' +
            '</div>';
          container.appendChild(row);
        });

        container.querySelectorAll('.home-card-src').forEach(function (inp) {
          inp.addEventListener('input', function () {
            const i = parseInt(this.getAttribute('data-i'), 10);
