          statusEl.textContent = 'Ошибка: ' + e.message;
          statusEl.className = 'status err';
        }
      });

      document.getElementById('downloadHomeMediaCardsBtn').addEventListener('click', function () {
        const payload = homeMediaCards.map(function (card) {
          const normalized = normalizeHomeMediaCard(card);
          return {
            href: normalized.href || '/index/',
            src: normalized.src || '',
            alt: normalized.alt || '',
            ratio: normalized.ratio || 'aspect-16-9',
            as: normalized.as || 'image',
            loading: 'lazy',
            size: normalized.size || 'normal',
            edge: normalized.edge === 'left' || normalized.edge === 'right' ? normalized.edge : undefined
          };
        });
        const json = JSON.stringify(payload, null, 2);
        const blob = new Blob([json], { type: 'application/json' });
        const a = document.createElement('a');
        a.href = URL.createObjectURL(blob);
        a.download = 'home-media-cards.json';
        a.click();
        URL.revokeObjectURL(a.href);
      });

      document.getElementById('addResearchCardBtn').addEventListener('click', function () {
        const maxNumber = researchCards.reduce(function (acc, item) {
          const n = Number(item.number || 0);
          return Number.isFinite(n) ? Math.max(acc, n) : acc;
        }, 0);
        researchCards.push({
          number: maxNumber + 1,
          src: '',
          alt: '',
          as: 'image',
          caption: '',
          date: ''
        });
        sortResearchCards();
        renderResearchCardsEditor();
        document.getElementById('researchCardsLoadStatus').textContent = 'Карточек: ' + researchCards.length;
      });

      document.getElementById('saveResearchCardsToGitHubBtn').addEventListener('click', async function () {
        const statusEl = document.getElementById('researchCardsGhStatus');
        const gh = parseRepoAndToken(statusEl);
        if (!gh) return;
        statusEl.textContent = 'Отправка…';
        statusEl.className = 'status';
        try {
          sessionStorage.setItem(REPO_KEY, gh.repo);
          const path = 'public/data/research-cards.json';
          const getRes = await fetch('https://api.github.com/repos/' + gh.owner + '/' + gh.repoName + '/contents/' + path, {
            headers: { 'Accept': 'application/vnd.github.v3+json', 'Authorization': 'token ' + gh.token }
          });
          let sha = null;
          if (getRes.ok) {
            const data = await getRes.json();
            sha = data.sha;
          } else if (getRes.status !== 404) {
            const err = await getRes.json().catch(() => ({}));
            throw new Error(err.message || getRes.statusText);
          }
          sortResearchCards();
          const payload = researchCards
            .map(function (card, i) { return normalizeResearchCard(card, i + 1); })
            .filter(function (card) { return Boolean(card.src && card.src.trim()); });
          const content = JSON.stringify(payload, null, 2);
          const body = {
            message: 'Update research-cards.json from admin',
            content: btoa(unescape(encodeURIComponent(content))),
            branch: 'main'
          };
          if (sha) body.sha = sha;
          const putRes = await fetch('https://api.github.com/repos/' + gh.owner + '/' + gh.repoName + '/contents/' + path, {
            method: 'PUT',
            headers: {
              'Accept': 'application/vnd.github.v3+json',
              'Authorization': 'token ' + gh.token,
              'Content-Type': 'application/json'
            },
            body: JSON.stringify(body)
          });
          if (!putRes.ok) {
            const err = await putRes.json().catch(() => ({}));
            throw new Error(err.message || putRes.statusText);
          }
          statusEl.textContent = 'Карточки Research сохранены. Деплой запустится по push в main.';
          statusEl.className = 'status ok';
        } catch (e) {
          statusEl.textContent = 'Ошибка: ' + e.message;
          statusEl.className = 'status err';
        }
      });

      document.getElementById('downloadResearchCardsBtn').addEventListener('click', function () {
        sortResearchCards();
        const payload = researchCards
          .map(function (card, i) { return normalizeResearchCard(card, i + 1); })
          .filter(function (card) { return Boolean(card.src && card.src.trim()); });
        const json = JSON.stringify(payload, null, 2);
        const blob = new Blob([json], { type: 'application/json' });
        const a = document.createElement('a');
        a.href = URL.createObjectURL(blob);
        a.download = 'research-cards.json';
        a.click();
        URL.revokeObjectURL(a.href);
      });

      document.getElementById('researchViewListBtn').addEventListener('click', function () {
        researchCardsView = 'list';
        renderResearchCardsEditor();
      });

      document.getElementById('researchViewGridBtn').addEventListener('click', function () {
        researchCardsView = 'grid';
        renderResearchCardsEditor();
      });

      document.getElementById('researchViewPreviewBtn').addEventListener('click', function () {
        researchCardsView = 'preview';
        renderResearchCardsEditor();
      });

      document.getElementById('researchCardScaleRange').addEventListener('input', function () {
        const value = Number(this.value);
        researchCardsScale = Number.isFinite(value) ? Math.max(70, Math.min(140, Math.round(value))) : 100;
        syncResearchScaleUi();
        if (researchCardsView === 'grid' || researchCardsView === 'preview') renderResearchCardsEditor();
      });

      function initApp() {
        initAdminNav();
        setActivePane('projectsPane');
        loadProjects();
        loadHomeMediaCards();
        loadResearchCards();
      }

      checkAuth();
    })();
  </script>
</AdminLayout>
