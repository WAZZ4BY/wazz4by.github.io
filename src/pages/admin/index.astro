      function parseRepoAndToken(statusEl) {
        const repoInput = document.getElementById('ghRepo');
        const tokenInput = document.getElementById('ghToken');
        const repo = (repoInput?.value || '').trim();
        const token = (tokenInput?.value || '').trim();
        if (!repo || !token) {
          statusEl.textContent = 'Укажите репозиторий и токен выше.';
          statusEl.className = 'status err';
          return null;
        }
        const parts = repo.split('/').filter(Boolean);
        if (parts.length !== 2) {
          statusEl.textContent = 'Репозиторий в формате owner/repo';
          statusEl.className = 'status err';
          return null;
        }
        return { owner: parts[0], repoName: parts[1], token: token, repo: repo };
      }

      function sanitizeFileName(name) {
        const safe = String(name || 'image')
          .toLowerCase()
          .replace(/[^a-z0-9._-]+/g, '-')
          .replace(/-+/g, '-')
          .replace(/^-|-$/g, '');
        return safe || 'image';
      }

      async function fileToBase64(file) {
        const buffer = await file.arrayBuffer();
        const bytes = new Uint8Array(buffer);
        let binary = '';
        const chunk = 0x8000;
        for (let i = 0; i < bytes.length; i += chunk) {
          const part = bytes.subarray(i, i + chunk);
          binary += String.fromCharCode.apply(null, part);
        }
        return btoa(binary);
      }

      async function uploadFileToGitHub(file, targetDir, commitMessage) {
        const statusEl = document.getElementById('homeMediaCardsGhStatus');
        const gh = parseRepoAndToken(statusEl);
        if (!gh) throw new Error('Нет данных GitHub');

        sessionStorage.setItem(REPO_KEY, gh.repo);

        const fileName = Date.now() + '-' + sanitizeFileName(file.name);
        const contentPath = targetDir + '/' + fileName;
        const apiUrl = 'https://api.github.com/repos/' + gh.owner + '/' + gh.repoName + '/contents/' + contentPath;

        const getRes = await fetch(apiUrl, {
          headers: { 'Accept': 'application/vnd.github.v3+json', 'Authorization': 'token ' + gh.token }
        });
        let sha = null;
        if (getRes.ok) {
          const data = await getRes.json();
          sha = data.sha;
        } else if (getRes.status !== 404) {
          const err = await getRes.json().catch(() => ({}));
          throw new Error(err.message || getRes.statusText);
        }

        const body = {
          message: commitMessage,
          content: await fileToBase64(file),
          branch: 'main'
        };
        if (sha) body.sha = sha;

        const putRes = await fetch(apiUrl, {
          method: 'PUT',
          headers: {
            'Accept': 'application/vnd.github.v3+json',
            'Authorization': 'token ' + gh.token,
            'Content-Type': 'application/json'
          },
          body: JSON.stringify(body)
        });

        if (!putRes.ok) {
          const err = await putRes.json().catch(() => ({}));
          throw new Error(err.message || putRes.statusText);
        }

        const publicPath = targetDir.replace(/^public\//, '');
        return '/' + publicPath + '/' + fileName;
      }

