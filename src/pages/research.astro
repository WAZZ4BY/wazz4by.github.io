---
import BaseLayout from '../layouts/BaseLayout.astro';
import InnerPageHeader from '../components/InnerPageHeader.astro';
import { getResearchCards } from '../lib/researchCards';

const researchItems = getResearchCards();

function extractIframeSrc(raw: string): string {
  const s = String(raw || '').trim();
  const m = s.match(/<iframe[\s\S]*?src=["']([^"']+)["']/i);
  if (m && m[1]) return m[1].trim();
  return s;
}

function getKinescopeEmbedUrl(raw: string): string {
  const s = extractIframeSrc(raw);
  if (!s) return '';
  if (/kinescope\.(io|ru)\/embed\//.test(s)) return s;
  const m = s.match(/https?:\/\/(?:kinescope\.(?:io|ru))\/([^/?#]+)/);
  if (m && m[1]) return `https://kinescope.io/embed/${m[1]}?autoplay=1&muted=1`;
  return s;
}
---

<BaseLayout title="Research" variant="inner" hideHeader>
  <div class="inner-page">
    <div class="inner-page__grid">
      <InnerPageHeader activePage="research" />
      <main class="inner-page__main research-page research-stage">
        <div class="research-grid">
          {researchItems.map((item) => (
            <div
              class="research-card"
              data-media-type={item.as || 'image'}
              data-media-src={item.src}
              data-media-alt={item.alt || `Research ${item.number}`}
              data-media-caption={item.caption || ''}
              data-media-date={item.date || ''}
            >
              <div class="research-card__image">
                {item.as === 'kinescope' ? (
                  <iframe
                    src={getKinescopeEmbedUrl(item.src)}
                    title={item.alt || `Research ${item.number}`}
                    loading="lazy"
                    frameborder="0"
                    allow="autoplay; fullscreen; picture-in-picture"
                    allowfullscreen
                  />
                ) : (
                  <img src={item.src} alt={item.alt || `Research ${item.number}`} loading="lazy" />
                )}
              </div>
              <button class="research-card__open" type="button" aria-label={`Open ${item.alt || `Research ${item.number}`}`} />
            </div>
          ))}
        </div>
      </main>
    </div>
  </div>
</BaseLayout>

<style>
  :global(.research-lightbox-open .page-header) {
    opacity: 0;
    visibility: hidden;
  }

  :global(.research-lightbox-open .research-stage) {
    filter: blur(15px);
    opacity: 0.5;
    pointer-events: none;
    user-select: none;
  }

  :global(.research-card__open) {
    position: absolute;
    inset: 0;
    border: 0;
    background: transparent;
    cursor: pointer;
  }

  :global(.research-card__open:focus),
  :global(.research-card__open:focus-visible) {
    outline: none;
    box-shadow: none;
  }

  :global(.research-lightbox) {
    position: fixed;
    inset: 0;
    z-index: 1200;
    display: none;
    align-items: center;
    justify-content: center;
    padding: 0 40px;
  }

  :global(.research-lightbox.is-open) {
    display: flex;
  }

  :global(.research-lightbox__zone) {
    position: absolute;
    top: 0;
    bottom: 0;
    width: 50%;
    z-index: 1;
    border: 0;
    background: transparent;
  }

  :global(.research-lightbox__zone--left) {
    left: 0;
    cursor: pointer;
  }

  :global(.research-lightbox__zone--right) {
    right: 0;
    cursor: pointer;
  }

  :global(.research-lightbox__media-wrap) {
    position: relative;
    z-index: 3;
    max-width: min(90vw, 1400px);
    max-height: max(220px, calc(100vh - 300px));
    width: auto;
    height: auto;
    cursor: pointer;
  }

  :global(.research-lightbox__media-wrap img),
  :global(.research-lightbox__media-wrap iframe) {
    display: block;
    width: auto;
    max-width: 100%;
    height: auto;
    max-height: max(220px, calc(100vh - 300px));
    margin: 0 auto;
  }

  :global(.research-lightbox__media-wrap),
  :global(.research-lightbox__media-wrap:focus),
  :global(.research-lightbox__media-wrap:focus-visible),
  :global(.research-lightbox__media-wrap img:focus),
  :global(.research-lightbox__media-wrap iframe:focus),
  :global(.research-lightbox__arrow:focus),
  :global(.research-lightbox__arrow:focus-visible),
  :global(.research-lightbox__zone:focus),
  :global(.research-lightbox__zone:focus-visible) {
    outline: none;
    box-shadow: none;
  }

  :global(.research-lightbox__media-wrap iframe) {
    width: min(90vw, 1400px);
    height: max(220px, calc(100vh - 300px));
    border: 0;
  }

  :global(.research-lightbox__meta) {
    position: fixed;
    bottom: 50px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 4;
    text-align: center;
    font-family: 'SuisseIntl', sans-serif;
    font-size: 12px;
    font-weight: 500;
    line-height: 1.2;
    color: #000;
    white-space: nowrap;
  }

  :global(.research-lightbox__close) {
    position: fixed;
    top: 50px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 4;
    border: 0;
    background: transparent;
    text-align: center;
    font-family: 'SuisseIntl', sans-serif;
    font-size: 12px;
    font-weight: 500;
    line-height: 1.2;
    color: #000;
    cursor: pointer;
  }

  :global(.research-lightbox__close:focus),
  :global(.research-lightbox__close:focus-visible) {
    outline: none;
    box-shadow: none;
  }

</style>

<script>
  (function () {
    function extractIframeSrc(raw) {
      const s = String(raw || '').trim();
      const m = s.match(/<iframe[\s\S]*?src=["']([^"']+)["']/i);
      if (m && m[1]) return m[1].trim();
      return s;
    }

    function getKinescopeEmbedUrl(raw, withSound) {
      const s = extractIframeSrc(raw);
      if (!s) return '';
      function tuneUrl(url) {
        try {
          const u = new URL(url);
          u.searchParams.set('autoplay', '1');
          if (withSound) {
            u.searchParams.delete('muted');
            u.searchParams.delete('mute');
            u.searchParams.set('muted', '0');
          } else {
            u.searchParams.set('muted', '1');
          }
          return u.toString();
        } catch (_) {
          return url;
        }
      }
      if (/kinescope\.(io|ru)\/embed\//.test(s)) {
        return tuneUrl(s);
      }
      const m = s.match(/https?:\/\/(?:kinescope\.(?:io|ru))\/([^/?#]+)/);
      if (m && m[1]) return tuneUrl('https://kinescope.io/embed/' + m[1]);
      return s;
    }

    const cards = Array.from(document.querySelectorAll('.research-card'));
    if (cards.length === 0) return;
    let activeIndex = -1;

    const lightbox = document.createElement('div');
    lightbox.className = 'research-lightbox';
    lightbox.innerHTML =
      '<button class="research-lightbox__close" type="button" aria-label="Close">Close</button>' +
      '<button class="research-lightbox__zone research-lightbox__zone--left" type="button" aria-label="Previous slide"></button>' +
      '<button class="research-lightbox__zone research-lightbox__zone--right" type="button" aria-label="Next slide"></button>' +
      '<div class="research-lightbox__media-wrap"></div>' +
      '<div class="research-lightbox__meta" aria-live="polite"></div>';
    document.body.appendChild(lightbox);

    const closeBtn = lightbox.querySelector('.research-lightbox__close');
    const mediaWrap = lightbox.querySelector('.research-lightbox__media-wrap');
    const meta = lightbox.querySelector('.research-lightbox__meta');
    const leftZone = lightbox.querySelector('.research-lightbox__zone--left');
    const rightZone = lightbox.querySelector('.research-lightbox__zone--right');

    function closeLightbox() {
      lightbox.classList.remove('is-open');
      document.body.classList.remove('research-lightbox-open');
      mediaWrap.innerHTML = '';
      meta.textContent = '';
      activeIndex = -1;
      const focused = document.activeElement;
      if (focused && typeof focused.blur === 'function') focused.blur();
    }

    function renderLightboxByIndex(index) {
      const safeIndex = (index + cards.length) % cards.length;
      const card = cards[safeIndex];
      const type = card.getAttribute('data-media-type') || 'image';
      const src = card.getAttribute('data-media-src') || '';
      const alt = card.getAttribute('data-media-alt') || '';
      const caption = card.getAttribute('data-media-caption') || '';
      const date = card.getAttribute('data-media-date') || '';

      if (!src) return;
      activeIndex = safeIndex;
      mediaWrap.innerHTML = '';

      if (type === 'kinescope') {
        const iframe = document.createElement('iframe');
        iframe.src = getKinescopeEmbedUrl(src, true);
        iframe.title = alt || 'Research video';
        iframe.setAttribute('allow', 'autoplay; fullscreen; picture-in-picture');
        iframe.setAttribute('allowfullscreen', '');
        iframe.setAttribute('loading', 'lazy');
        mediaWrap.appendChild(iframe);
      } else {
        const img = document.createElement('img');
        img.src = src;
        img.alt = alt || 'Research image';
        img.loading = 'eager';
        mediaWrap.appendChild(img);
      }

      const metaParts = [caption, date].filter(Boolean);
      meta.textContent = metaParts.join(' — ');
    }

    function openLightbox(index) {
      renderLightboxByIndex(index);
      lightbox.classList.add('is-open');
      document.body.classList.add('research-lightbox-open');
    }

    function nextSlide() {
      if (activeIndex < 0) return;
      renderLightboxByIndex(activeIndex + 1);
    }

    function prevSlide() {
      if (activeIndex < 0) return;
      renderLightboxByIndex(activeIndex - 1);
    }

    cards.forEach((card, index) => {
      const trigger = card.querySelector('.research-card__open');
      if (!trigger) return;
      trigger.addEventListener('click', function () {
        openLightbox(index);
      });
    });

    mediaWrap.addEventListener('click', closeLightbox);
    closeBtn.addEventListener('click', closeLightbox);
    leftZone.addEventListener('click', prevSlide);
    rightZone.addEventListener('click', nextSlide);

    window.addEventListener('keydown', function (e) {
      if (e.key === 'Escape') closeLightbox();
      if (!lightbox.classList.contains('is-open')) return;
      if (e.key === 'ArrowLeft') prevSlide();
      if (e.key === 'ArrowRight') nextSlide();
    });
  })();
</script>
