---
type MediaRatio =
  | 'aspect-16-9'
  | 'aspect-4-5'
  | 'aspect-3-4'
  | 'aspect-1-1'
  | 'aspect-original'
  | 'aspect-free';

interface Props {
  href?: string;
  src: string;
  alt?: string;
  ratio?: MediaRatio;
  title?: string;
  as?: 'image' | 'video' | 'vimeo' | 'kinescope';
  width?: number;
  height?: number;
  className?: string;
  loading?: 'lazy' | 'eager';
  caption?: string;
  cursorLabel?: string;
  videoPoster?: string;
}

const {
  href,
  src,
  alt = '',
  ratio = 'aspect-16-9',
  title,
  as = 'image',
  width,
  height,
  className = '',
  loading = 'lazy',
  caption,
  cursorLabel,
  videoPoster
} = Astro.props as Props;

const hasIntrinsicSize = Number(width) > 0 && Number(height) > 0;
const intrinsicRatio = hasIntrinsicSize ? `${width} / ${height}` : '';

const thumbnailStyle = [
  ratio === 'aspect-original' && intrinsicRatio
    ? `--media-card-original-ratio: ${intrinsicRatio}`
    : '',
  ratio === 'aspect-free' && intrinsicRatio
    ? `--media-card-free-ratio: ${intrinsicRatio}`
    : ''
]
  .filter(Boolean)
  .join('; ');

const rootClass = ['media-card', className].filter(Boolean).join(' ');
const thumbClass = ['media-card__thumbnail', '_thumbnail', ratio].join(' ');
const mediaClass = ['media-card__thumb', '_thumb'].join(' ');
const effectiveCursorLabel = typeof cursorLabel === 'string' ? cursorLabel.trim() : '';

function normalizeVimeoPlayerUrl(url: string): string {
  return url
    .replace(/%20/g, '')
    .replace(/&;\s*/g, '&')
    .replace(/\?&+/, '?')
    .replace(/&+$/, '');
}

function vimeoEmbedUrl(input: string | null): string | null {
  if (!input || !input.trim()) return null;
  const s = input.trim();
  const fullPlayerMatch = s.match(/https?:\/\/player\.vimeo\.com\/video\/\d+[\s\S]*/);
  if (fullPlayerMatch) {
    const url = fullPlayerMatch[0].replace(/["'\s].*$/, '').trim();
    return normalizeVimeoPlayerUrl(url);
  }
  const idFromPlayer = s.match(/player\.vimeo\.com\/video\/(\d+)/);
  if (idFromPlayer) return `https://player.vimeo.com/video/${idFromPlayer[1]}?background=1&autoplay=1&loop=1&muted=1`;
  const idFromPage = s.match(/(?:vimeo\.com\/)(?:video\/)?(\d+)/);
  if (idFromPage) return `https://player.vimeo.com/video/${idFromPage[1]}?background=1&autoplay=1&loop=1&muted=1`;
  const iframeSrc = s.match(/<iframe[\s\S]*?src=["']([^"']+)["']/);
  if (iframeSrc) {
    const src = iframeSrc[1];
    if (/player\.vimeo\.com\/video\/\d+/.test(src)) return normalizeVimeoPlayerUrl(src);
    const id = src.match(/video\/(\d+)/);
    if (id) return `https://player.vimeo.com/video/${id[1]}?background=1&autoplay=1&loop=1&muted=1`;
  }
  return null;
}

function kinescopeEmbedUrl(input: string | null): string | null {
  if (!input || !input.trim()) return null;
  const s = input.trim();
  const iframeSrc = s.match(/<iframe[\s\S]*?src=["']([^"']+)["']/);
  const candidate = iframeSrc ? iframeSrc[1].trim() : s.replace(/["'\s].*$/, '').trim();
  if (!candidate) return null;
  if (!/^https?:\/\//.test(candidate)) return null;
  if (!/kinescope\.(io|ru)/.test(candidate)) return null;
  if (/\/embed\//.test(candidate)) return candidate;
  const m = candidate.match(/https?:\/\/(?:kinescope\.(?:io|ru))\/([^/?#]+)/);
  if (m && m[1]) return `https://kinescope.io/embed/${m[1]}?autoplay=1&muted=1`;
  return candidate;
}

const vimeoSrc = as === 'vimeo' ? vimeoEmbedUrl(src) : null;
const kinescopeSrc = as === 'kinescope' ? kinescopeEmbedUrl(src) : null;
---

<div class={rootClass}>
  {href ? (
    <a class="media-card__link" href={href} title={title} data-cursor-label={effectiveCursorLabel || undefined}>
      <div class={thumbClass} style={thumbnailStyle || undefined}>
        {as === 'video' ? (
          <video
            class={mediaClass}
            src={src}
            width={width}
            height={height}
            poster={videoPoster}
            playsinline
            muted
            loop
            autoplay
            preload="metadata"
          />
        ) : as === 'vimeo' ? (
          <iframe
            class="media-card__thumb media-card__embed"
            src={vimeoSrc || src}
            title={title || alt || 'Vimeo video'}
            frameborder="0"
            allow="autoplay; fullscreen; picture-in-picture"
            allowfullscreen
          />
        ) : as === 'kinescope' ? (
          <iframe
            class="media-card__thumb media-card__embed"
            src={kinescopeSrc || src}
            title={title || alt || 'Kinescope video'}
            frameborder="0"
            allow="autoplay; fullscreen; picture-in-picture"
            allowfullscreen
          />
        ) : (
          <img
            class={mediaClass}
            src={src}
            alt={alt}
            width={width}
            height={height}
            loading={loading}
            decoding="async"
          />
        )}
      </div>
      {effectiveCursorLabel && <span class="media-card__cursor-label">{effectiveCursorLabel}</span>}
    </a>
  ) : (
    <div class="media-card__link media-card__link--static" title={title}>
      <div class={thumbClass} style={thumbnailStyle || undefined}>
        {as === 'video' ? (
          <video
            class={mediaClass}
            src={src}
            width={width}
            height={height}
            poster={videoPoster}
            playsinline
            muted
            loop
            autoplay
            preload="metadata"
          />
        ) : as === 'vimeo' ? (
          <iframe
            class="media-card__thumb media-card__embed"
            src={vimeoSrc || src}
            title={title || alt || 'Vimeo video'}
            frameborder="0"
            allow="autoplay; fullscreen; picture-in-picture"
            allowfullscreen
          />
        ) : as === 'kinescope' ? (
          <iframe
            class="media-card__thumb media-card__embed"
            src={kinescopeSrc || src}
            title={title || alt || 'Kinescope video'}
            frameborder="0"
            allow="autoplay; fullscreen; picture-in-picture"
            allowfullscreen
          />
        ) : (
          <img
            class={mediaClass}
            src={src}
            alt={alt}
            width={width}
            height={height}
            loading={loading}
            decoding="async"
          />
        )}
      </div>
      {effectiveCursorLabel && <span class="media-card__cursor-label">{effectiveCursorLabel}</span>}
    </div>
  )}

  {(title || caption) && (
    <div class="media-card__meta">
      {title && <div class="media-card__title">{title}</div>}
      {caption && <div class="media-card__caption">{caption}</div>}
    </div>
  )}
</div>

<style>
  .media-card {
    width: 100%;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .media-card__link {
    display: block;
    width: 100%;
    color: inherit;
    text-decoration: none;
    min-width: 0;
    position: relative;
  }

  .media-card__link--static {
    cursor: default;
  }

  .media-card__thumbnail {
    position: relative;
    width: 100%;
    overflow: hidden;
    min-width: 0;
    background: #f3f3f3;
  }

  .media-card__thumbnail.aspect-16-9 { aspect-ratio: 16 / 9; }
  .media-card__thumbnail.aspect-4-5 { aspect-ratio: 4 / 5; }
  .media-card__thumbnail.aspect-3-4 { aspect-ratio: 3 / 4; }
  .media-card__thumbnail.aspect-1-1 { aspect-ratio: 1 / 1; }
  .media-card__thumbnail.aspect-original { aspect-ratio: var(--media-card-original-ratio, auto); }
  .media-card__thumbnail.aspect-free { aspect-ratio: var(--media-card-free-ratio, auto); }

  .media-card__thumb {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    border: 0;
  }

  .media-card__thumbnail.aspect-original .media-card__thumb {
    object-fit: contain;
  }

  .media-card__thumbnail.aspect-free .media-card__thumb {
    height: auto;
    object-fit: contain;
  }

  .media-card__embed {
    border: 0;
    pointer-events: none;
  }

  .media-card__cursor-label {
    position: fixed;
    left: 0;
    top: 0;
    transform: translate3d(-9999px, -9999px, 0);
    padding: 0;
    margin: 0;
    font-family: 'SuisseIntl', sans-serif;
    font-size: 16pt;
    font-weight: 500;
    line-height: 1;
    opacity: 0;
    transition: opacity 0.12s ease;
    pointer-events: none;
    z-index: 500;
    white-space: nowrap;
  }

  :global(body.is-home) .media-card__cursor-label {
    color: #fff;
    mix-blend-mode: difference;
  }

  .media-card__link:hover .media-card__cursor-label,
  .media-card__link:focus-visible .media-card__cursor-label {
    opacity: 1;
  }

  .media-card__meta {
    display: grid;
    gap: 2px;
    min-width: 0;
  }

  .media-card__title,
  .media-card__caption {
    margin: 0;
    color: #111;
    font-family: 'SuisseIntl', sans-serif;
    font-size: 12px;
    line-height: 1.2;
    word-break: break-word;
  }

  .media-card__caption {
    opacity: 0.65;
  }
</style>

<script>
  (function () {
    const links = Array.from(document.querySelectorAll('.media-card__link[data-cursor-label]'));
    if (!links.length) return;

    links.forEach(function (link) {
      const label = link.querySelector('.media-card__cursor-label');
      if (!label) return;

      function placeLabel(e) {
        const x = e.clientX + 14;
        const y = e.clientY + 12;
        label.style.transform = 'translate3d(' + x + 'px, ' + y + 'px, 0)';
      }

      link.addEventListener('mouseenter', placeLabel);
      link.addEventListener('mousemove', placeLabel);
      link.addEventListener('mouseleave', function () {
        label.style.transform = 'translate3d(-9999px, -9999px, 0)';
      });
      link.addEventListener('blur', function () {
        label.style.transform = 'translate3d(-9999px, -9999px, 0)';
      });
    });
  })();
</script>
